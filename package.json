{
  "name": "wattbike-bmx-race",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n bridge,web -c cyan,green \"npm:bridge\" \"npm:web\"",
    "web": "vite --host 127.0.0.1",
    "bridge": "node bridge/server.mjs",
    "bridge:ant": "WATTBIKE_INPUT=ant node bridge/server.mjs",
    "assets:clean": "node scripts/clean-sprite-alpha.mjs",
    "tracks:build": "node scripts/build-track-database.mjs",
    "build": "npm run tracks:build && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "ant-plus-next": "^0.4.0",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.562.0",
    "pngjs": "^7.0.0",
    "vite": "^8.1.0",
    "ws": "^8.18.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
