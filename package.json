{
  "name": "wattbike-bmx-race",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n ant-bridge,web -c cyan,green \"npm:bridge\" \"npm:web\"",
    "dev:ant": "concurrently -k -n ant-bridge,web -c cyan,green \"npm:bridge:ant\" \"npm:web\"",
    "dev:sim": "concurrently -k -n sim-bridge,web -c cyan,green \"npm:bridge:sim\" \"npm:web\"",
    "web": "vite --host 127.0.0.1",
    "bridge": "node bridge/server.mjs",
    "bridge:ant": "WATTBIKE_INPUT=ant node bridge/server.mjs",
    "bridge:sim": "WATTBIKE_INPUT=sim node bridge/server.mjs",
    "start": "node cloud/server.mjs",
    "cloud": "npm run build && node cloud/server.mjs",
    "ant:capture": "node scripts/capture-ant-wattbike.mjs",
    "ble:inspect": "node bridge/ble-inspector.mjs",
    "assets:clean": "node scripts/clean-sprite-alpha.mjs",
    "tracks:import:usabmx": "node scripts/import-usabmx-tracks.mjs",
    "tracks:import:ffc": "node scripts/import-ffc-bmx-tracks.mjs",
    "tracks:import:bmxnz": "node scripts/import-bmxnz-tracks.mjs",
    "tracks:import:osm": "node scripts/import-osm-bmx-tracks.mjs",
    "tracks:import:official": "npm run tracks:import:usabmx && npm run tracks:import:ffc && npm run tracks:import:bmxnz",
    "tracks:build": "node scripts/build-track-database.mjs",
    "build": "npm run tracks:build && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@vitejs/plugin-react": "^6.0.3",
    "ant-plus-next": "^0.4.0",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.562.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "serialport": "^13.0.0",
    "vite": "^8.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "node-gyp": "^13.0.0",
    "tar": "^7.5.19"
  }
}
